<%- include('../partials/header', { title: 'Admin' }) %>
<%- include('../partials/navbar') %>

<section class="section">
  <div class="container">
    <h1 style="font-size:1.8rem; font-weight:800; margin-bottom:0.5rem;">Panel <span style="color:#D4AF37;">Administrateur</span></h1>
    <p style="color:#6B6B6B; margin-bottom:2rem;">Vue d'ensemble de la plateforme</p>

    <% if (success) { %><div class="alert alert-success"><i class='bx bx-check-circle'></i> <%= success %></div><% } %>

    <div class="stat-cards" style="margin-bottom:2.5rem;">
      <div class="stat-card">
        <i class='bx bx-group' style="font-size:1.8rem; color:var(--gold); margin-bottom:0.5rem; display:block;"></i>
        <div class="number"><%= stats.totalUsers %></div>
        <div class="label">Utilisateurs</div>
      </div>
      <div class="stat-card">
        <i class='bx bx-list-ul' style="font-size:1.8rem; color:var(--gold); margin-bottom:0.5rem; display:block;"></i>
        <div class="number"><%= stats.totalAnnonces %></div>
        <div class="label">Annonces totales</div>
      </div>
      <div class="stat-card">
        <i class='bx bx-check-circle' style="font-size:1.8rem; color:var(--gold); margin-bottom:0.5rem; display:block;"></i>
        <div class="number"><%= stats.annoncesActives %></div>
        <div class="label">Annonces actives</div>
      </div>
      <div class="stat-card">
        <i class='bx bx-block' style="font-size:1.8rem; color:var(--gold); margin-bottom:0.5rem; display:block;"></i>
        <div class="number"><%= stats.usersBannis %></div>
        <div class="label">Comptes bannis</div>
      </div>
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:1rem;">
      <a href="/admin/users" class="btn btn-gold btn-lg" style="justify-content:center;">
        <i class='bx bx-group'></i> Gérer les utilisateurs
      </a>
      <a href="/admin/annonces" class="btn btn-dark btn-lg" style="justify-content:center;">
        <i class='bx bx-list-ul'></i> Gérer les annonces
      </a>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>