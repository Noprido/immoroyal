<%- include('../partials/header', { title: 'Annonces — Admin' }) %>
<%- include('../partials/navbar') %>

<section class="section">
  <div class="container">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:2rem; flex-wrap:wrap; gap:1rem;">
      <h1 style="font-size:1.8rem; font-weight:800;">
        <i class='bx bx-list-ul' style="color:var(--gold);"></i> <span style="color:#D4AF37;">Toutes les annonces</span>
      </h1>
      <a href="/admin/dashboard" class="btn btn-outline btn-sm">
        <i class='bx bx-arrow-back'></i> Retour
      </a>
    </div>

    <% if (success) { %><div class="alert alert-success"><i class='bx bx-check-circle'></i> <%= success %></div><% } %>
    <% if (error) { %><div class="alert alert-error"><i class='bx bx-error-circle'></i> <%= error %></div><% } %>

    <!-- Barre de recherche + filtres -->
    <div style="background:#fff; border-radius:12px; box-shadow:0 4px 24px rgba(0,0,0,0.08); padding:1.25rem; margin-bottom:2rem;">
      <form action="/admin/annonces" method="GET" style="display:grid; grid-template-columns:1fr auto auto; gap:0.75rem; align-items:end;">
        <div class="form-group" style="margin:0;">
          <label class="form-label">Rechercher</label>
          <input type="text" name="q" class="form-control" value="<%= filtres.q || '' %>"
                 placeholder="Titre, ville, quartier, ID...">
        </div>
        <div class="form-group" style="margin:0;">
          <label class="form-label">Statut</label>
          <select name="statut" class="form-control">
            <option value="">Tous</option>
            <option value="actif" <%= filtres.statut === 'actif' ? 'selected' : '' %>>Actives</option>
            <option value="inactif" <%= filtres.statut === 'inactif' ? 'selected' : '' %>>Inactives</option>
            <option value="suspendu" <%= filtres.statut === 'suspendu' ? 'selected' : '' %>>Suspendues</option>
          </select>
        </div>
        <div style="display:flex; gap:0.5rem; align-items:flex-end;">
          <button type="submit" class="btn btn-gold btn-sm"><i class='bx bx-search'></i> Filtrer</button>
          <a href="/admin/annonces" class="btn btn-outline btn-sm"><i class='bx bx-reset'></i></a>
        </div>
      </form>
    </div>

    <p style="font-size:0.85rem; color:#6B6B6B; margin-bottom:1rem;">
      <strong><%= annonces.length %></strong> annonce<%= annonces.length !== 1 ? 's' : '' %> trouvée<%= annonces.length !== 1 ? 's' : '' %>
    </p>

    <% if (annonces.length === 0) { %>
      <div class="empty-state">
        <i class='bx bx-search-alt' style="font-size:3rem; color:var(--grey); display:block; margin-bottom:1rem;"></i>
        <h3>Aucune annonce trouvée</h3>
        <p>Essayez d'autres critères de recherche.</p>
      </div>
    <% } else { %>

      <!-- Desktop : tableau -->
      <div class="table-wrapper admin-table-desktop">
        <table>
          <thead>
            <tr>
              <th>Annonce</th>
              <th>Auteur</th>
              <th>Ville</th>
              <th>Loyer</th>
              <th>Date</th>
              <th>Statut</th>
              <th>En avant</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% annonces.forEach(a => { %>
              <tr>
                <td>
                  <a href="/annonces/<%= a.id %>" style="font-weight:600; color:#D4AF37; font-size:0.9rem;"><%= a.titre %></a>
                  <div style="font-size:0.75rem; color:#aaa; font-family:monospace; margin-top:0.1rem;"><%= a.id.slice(0, 8) %>...</div>
                  <div style="font-size:0.78rem; color:#6B6B6B;"><%= a.typeBien %></div>
                </td>
                <td style="font-size:0.85rem;"><%= a.auteurNom %></td>
                <td style="font-size:0.85rem;">
                  <i class='bx bx-map' style="color:var(--gold);"></i> <%= a.ville %>
                </td>
                <td style="font-weight:700; color:#B8960C; font-size:0.9rem;">
                  <%= a.loyer.toLocaleString('fr-FR') %> FCFA
                </td>
                <td style="font-size:0.82rem; color:#6B6B6B;">
                  <%= new Date(a.createdAt).toLocaleDateString('fr-FR') %>
                </td>
                <td>
                  <% if (a.suspendu) { %>
                    <span class="badge badge-red"><i class='bx bx-shield-x'></i> Suspendue</span>
                  <% } else if (a.actif !== false) { %>
                    <span class="badge badge-green"><i class='bx bx-check-circle'></i> Active</span>
                  <% } else { %>
                    <span class="badge badge-grey"><i class='bx bx-minus-circle'></i> Inactive</span>
                  <% } %>
                </td>
                <td>
                  <form action="/admin/annonces/<%= a.id %>/featured" method="POST">
                    <button class="btn <%= a.enAvant ? 'btn-gold' : 'btn-outline' %> btn-sm">
                      <i class='bx bx-star'></i> <%= a.enAvant ? 'Oui' : 'Non' %>
                    </button>
                  </form>
                </td>
                <td>
                  <div style="display:flex; gap:0.4rem; flex-wrap:wrap;">
                    <% if (!a.suspendu) { %>
                      <form action="/admin/annonces/<%= a.id %>/suspendre" method="POST"
                            onsubmit="return confirm('Suspendre cette annonce ? L\'utilisateur ne pourra pas la réactiver.')">
                        <button class="btn btn-danger btn-sm">
                          <i class='bx bx-block'></i> Suspendre
                        </button>
                      </form>
                    <% } else { %>
                      <form action="/admin/annonces/<%= a.id %>/reactiver" method="POST">
                        <button class="btn btn-outline btn-sm">
                          <i class='bx bx-check'></i> Réactiver
                        </button>
                      </form>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Mobile : cartes -->
      <div class="admin-cards-mobile">
        <% annonces.forEach(a => { %>
          <div class="admin-card">
            <div class="admin-card-header">
              <div style="flex:1; min-width:0;">
                <a href="/annonces/<%= a.id %>" style="font-weight:700; color:#D4AF37; font-size:0.95rem;"><%= a.titre %></a>
                <div style="font-size:0.72rem; color:#aaa; font-family:monospace; margin-top:0.1rem;"><%= a.id.slice(0, 12) %>...</div>
                <div style="font-size:0.78rem; color:#6B6B6B;"><%= a.typeBien %></div>
              </div>
              <div style="display:flex; flex-direction:column; align-items:flex-end; gap:0.3rem;">
                <% if (a.suspendu) { %>
                  <span class="badge badge-red"><i class='bx bx-shield-x'></i> Suspendue</span>
                <% } else if (a.actif !== false) { %>
                  <span class="badge badge-green"><i class='bx bx-check-circle'></i> Active</span>
                <% } else { %>
                  <span class="badge badge-grey"><i class='bx bx-minus-circle'></i> Inactive</span>
                <% } %>
              </div>
            </div>
            <div class="admin-card-body">
              <div class="admin-card-row">
                <span><i class='bx bx-user' style="color:var(--gold);"></i> <%= a.auteurNom %></span>
                <span style="font-weight:700; color:#B8960C;"><%= a.loyer.toLocaleString('fr-FR') %> FCFA</span>
              </div>
              <div class="admin-card-row">
                <span><i class='bx bx-map' style="color:var(--gold);"></i> <%= a.ville %></span>
                <span style="font-size:0.8rem; color:#6B6B6B;">
                  <i class='bx bx-calendar'></i> <%= new Date(a.createdAt).toLocaleDateString('fr-FR') %>
                </span>
              </div>
            </div>
            <div class="admin-card-actions">
              <form action="/admin/annonces/<%= a.id %>/featured" method="POST">
                <button class="btn <%= a.enAvant ? 'btn-gold' : 'btn-outline' %> btn-sm">
                  <i class='bx bx-star'></i> <%= a.enAvant ? 'En avant' : 'Mettre en avant' %>
                </button>
              </form>
              <% if (!a.suspendu) { %>
                <form action="/admin/annonces/<%= a.id %>/suspendre" method="POST"
                      onsubmit="return confirm('Suspendre cette annonce ?')">
                  <button class="btn btn-danger btn-sm">
                    <i class='bx bx-block'></i> Suspendre
                  </button>
                </form>
              <% } else { %>
                <form action="/admin/annonces/<%= a.id %>/reactiver" method="POST">
                  <button class="btn btn-outline btn-sm">
                    <i class='bx bx-check'></i> Réactiver
                  </button>
                </form>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>

    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
