<%- include('../partials/header', { title: 'Annonces' }) %>
<%- include('../partials/navbar') %>

<section class="section">
  <div class="container">
    <% if (error) { %><div class="alert alert-error"><i class='bx bx-error-circle'></i> <%= error %></div><% } %>

    <!-- Filtres -->
    <div style="background:#fff; border-radius:12px; box-shadow:0 4px 24px rgba(0,0,0,0.08); padding:1.5rem; margin-bottom:2rem;">
      <h3 style="font-size:0.85rem; text-transform:uppercase; letter-spacing:1px; color:#6B6B6B; margin-bottom:1rem;">Filtrer les annonces</h3>
      <form action="/annonces" method="GET" class="search-grid">
        <div class="form-group">
          <label class="form-label">Ville / Commune</label>
          <input type="text" name="ville" class="form-control" data-autocomplete="ville"
                value="<%= filtres.ville || '' %>"
                placeholder="Cotonou, Abomey-Calavi..." autocomplete="off">
        </div>
        <div class="form-group">
          <label class="form-label">Quartier / Village</label>
          <input type="text" name="quartier" class="form-control" data-autocomplete="quartier"
                value="<%= filtres.quartier || '' %>"
                placeholder="Fidjrossè, Akpakpa..." autocomplete="off">
        </div>
        <div class="form-group">
          <label class="form-label">Type de bien</label>
          <select name="typeBien" class="form-control">
            <option value="">Tous les types</option>
            <% typesBien.forEach(t => { %>
              <option value="<%= t %>" <%= filtres.typeBien === t ? 'selected' : '' %>><%= t %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Prix min</label>
          <input type="number" name="prixMin" class="form-control" value="<%= filtres.prixMin || '' %>" placeholder="0">
        </div>
        <div class="form-group">
          <label class="form-label">Prix max</label>
          <input type="number" name="prixMax" class="form-control" value="<%= filtres.prixMax || '' %>" placeholder="500 000">
        </div>
        <div class="form-group" style="justify-content:flex-end; gap:0.5rem; flex-direction:row; align-items:flex-end;">
          <a href="/annonces" class="btn btn-outline btn-sm"><i class='bx bx-reset'></i> Reset</a>
          <button type="submit" class="btn btn-gold btn-sm"><i class='bx bx-search'></i> Filtrer</button>
        </div>
      </form>
    </div>

    <!-- Résultats -->
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
      <h2 class="section-title"><%= annonces.length %> annonce<%= annonces.length !== 1 ? 's' : '' %> trouvée<%= annonces.length !== 1 ? 's' : '' %></h2>
      <% if (user) { %>
        <a href="/annonces/creer" class="btn btn-gold"><i class='bx bx-plus'></i> Publier</a>
      <% } %>
    </div>

    <% if (annonces.length === 0) { %>
      <div class="empty-state">
        <i class='bx bx-search-alt' style="font-size:3rem; color:var(--grey); display:block; margin-bottom:1rem;"></i>
        <h3>Aucune annonce trouvée</h3>
        <p>Essayez d'autres critères de recherche.</p>
      </div>
    <% } else { %>
      <div class="annonces-grid">
        <% annonces.forEach(annonce => { %>
          <a href="/annonces/<%= annonce.id %>" class="card-annonce <%= annonce.enAvant ? 'en-avant' : '' %>">
            <div class="card-photo">
              <% if (annonce.photos && annonce.photos.length > 0) { %>
                <img src="<%= annonce.photos[0] %>" alt="<%= annonce.titre %>">
              <% } else { %>
                <div class="card-photo-placeholder"><i class='bx bx-home-alt-2'></i></div>
              <% } %>
              <span class="badge-type"><%= annonce.typeBien %></span>
              <% if (annonce.enAvant) { %><span class="badge-avant"><i class='bx bx-star'></i> En avant</span><% } %>
            </div>
            <div class="card-body">
              <div class="card-price"><%= annonce.loyer.toLocaleString('fr-FR') %> FCFA <span>/ mois</span></div>
              <div class="card-title"><%= annonce.titre %></div>
              <div class="card-location">
                <i class='bx bx-map'></i>
                <%= annonce.ville %><% if (annonce.quartier) { %>, <%= annonce.quartier %><% } %>
              </div>
              <div class="card-infos">
                <% if (annonce.nbPieces) { %>
                  <span><i class='bx bx-building-house bx-trfm'></i> <%= annonce.nbPieces %> pièce<%= annonce.nbPieces > 1 ? 's' : '' %></span>
                <% } %>
                <% if (annonce.nbDouches) { %>
                  <span><i class='bx bx-droplet bx-trfm'></i> <%= annonce.nbDouches %> douche<%= annonce.nbDouches > 1 ? 's' : '' %></span>
                <% } %>
                <span style="margin-left:auto; color:#D4AF37; font-size:0.75rem;">
                  <%= new Date(annonce.createdAt).toLocaleDateString('fr-FR') %>
                </span>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>
