<%- include('../partials/header', { title: 'Publier une annonce' }) %>
<%- include('../partials/navbar') %>

<div class="page-form">
  <h1 style="font-size:1.8rem; font-weight:800; margin-bottom:0.5rem;">Publier une <span style="color:#D4AF37;">annonce</span></h1>
  <p style="color:#6B6B6B; margin-bottom:1.5rem;">Remplissez les informations de votre bien</p>

  <% if (error) { %><div class="alert alert-error"><i class='bx bx-error-circle'></i> <%= error %></div><% } %>

  <!-- Stepper -->
  <div class="stepper">
    <div class="stepper-item active" data-step="1">
      <span class="stepper-circle">1</span><span class="stepper-label">Général</span>
    </div>
    <div class="stepper-line"></div>
    <div class="stepper-item" data-step="2">
      <span class="stepper-circle">2</span><span class="stepper-label">Finances</span>
    </div>
    <div class="stepper-line"></div>
    <div class="stepper-item" data-step="3">
      <span class="stepper-circle">3</span><span class="stepper-label">Détails</span>
    </div>
    <div class="stepper-line"></div>
    <div class="stepper-item" data-step="4">
      <span class="stepper-circle">4</span><span class="stepper-label">Médias</span>
    </div>
  </div>

  <form action="/annonces/creer" method="POST" enctype="multipart/form-data" id="annonceForm">

    <!-- ══════════════════════════════════════════════════
         ÉTAPE 1 : Infos générales
    ══════════════════════════════════════════════════ -->
    <div class="form-step active" data-step="1">
      <div class="form-card">
        <h3><i class='bx bx-clipboard'></i> Informations générales</h3>
        <div class="form-grid-2">

          <div class="form-group" style="grid-column:1/-1;">
            <label class="form-label">Titre de l'annonce *</label>
            <input type="text" name="titre" class="form-control"
                   placeholder="Ex: Beau studio meublé à Fidjrossè" required>
          </div>

          <!-- Type de transaction -->
          <div class="form-group" style="grid-column:1/-1;">
            <label class="form-label">Type de transaction *</label>
            <div class="transaction-toggle" id="transactionToggle">
              <label class="transaction-option">
                <input type="radio" name="typeTransaction" value="location" checked
                       onchange="onTransactionChange(this)">
                <span><i class='bx bx-key'></i> À louer</span>
              </label>
              <label class="transaction-option">
                <input type="radio" name="typeTransaction" value="vente"
                       onchange="onTransactionChange(this)">
                <span><i class='bx bx-transfer'></i> À vendre</span>
              </label>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">Type de bien *</label>
            <select name="typeBien" id="typeBien" class="form-control" required
                    onchange="onTypeBienChange(this)">
              <option value="">Choisir...</option>
              <% typesBien.forEach(t => { %>
                <option value="<%= t %>"
                  <%= typesVenteDefaut.includes(t) ? 'data-vente-defaut="true"' : '' %>>
                  <%= t %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label">Ville / Commune *</label>
            <input type="text" name="ville" class="form-control" data-autocomplete="ville"
                   placeholder="Cotonou, Abomey-Calavi..." autocomplete="off" required>
          </div>

          <div class="form-group">
            <label class="form-label">Quartier / Village *</label>
            <input type="text" name="quartier" class="form-control" data-autocomplete="quartier"
                   placeholder="Fidjrossè, Akpakpa..." autocomplete="off" required>
          </div>

          <div class="form-group" style="grid-column:1/-1;">
            <label class="form-label">Description (facultatif)</label>
            <textarea name="description" class="form-control"
                      placeholder="Décrivez votre bien (emplacement, état, commodités...)"></textarea>
          </div>
        </div>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════
         ÉTAPE 2 : Finances
    ══════════════════════════════════════════════════ -->
    <div class="form-step" data-step="2">
      <div class="form-card">
        <h3><i class='bx bx-wallet'></i> Informations financières</h3>
        <div class="form-grid-2">

          <!-- Prix / Loyer (label dynamique selon transaction) -->
          <div class="form-group" id="groupPrix">
            <label class="form-label" id="labelPrix">Loyer *</label>
            <div style="position:relative;">
              <input type="number" name="loyer" id="inputLoyer" class="form-control"
                     placeholder="50 000" min="0" required>
              <input type="number" name="prix" id="inputPrix" class="form-control"
                     placeholder="5 000 000" min="0" style="display:none;">
              <span style="position:absolute; right:0.9rem; top:50%; transform:translateY(-50%);
                           font-size:0.8rem; color:var(--grey); pointer-events:none;">FCFA</span>
            </div>
          </div>

          <!-- Durée de location (masqué en vente) -->
          <div class="form-group" id="groupDuree">
            <label class="form-label">Durée *</label>
            <select name="dureeLocation" class="form-control" required>
              <% dureesLocation.forEach(d => { %>
                <option value="<%= d.value %>" <%= d.value === 'mois' ? 'selected' : '' %>>
                  <%= d.label %>
                </option>
              <% }) %>
            </select>
          </div>

          <!-- Champs location uniquement -->
          <div class="form-group form-location-only">
            <label class="form-label">Mois d'avance *</label>
            <input type="number" name="moisAvance" class="form-control"
                   placeholder="3" min="0" required>
          </div>
          <div class="form-group form-location-only">
            <label class="form-label">Caution eau (FCFA) *</label>
            <input type="number" name="cautionEau" class="form-control"
                   placeholder="10 000" min="0" required>
          </div>
          <div class="form-group form-location-only">
            <label class="form-label">Caution électricité (FCFA) *</label>
            <input type="number" name="cautionElec" class="form-control"
                   placeholder="10 000" min="0" required>
          </div>

          <!-- Toujours visible -->
          <div class="form-group">
            <label class="form-label">Commission démarcheur (FCFA) *</label>
            <input type="number" name="commissionDemarcheur" class="form-control"
                   placeholder="0" min="0" required>
          </div>
        </div>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════
         ÉTAPE 3 : Caractéristiques (masqué pour Terrain)
    ══════════════════════════════════════════════════ -->
    <div class="form-step" data-step="3">
      <div class="form-card" id="cardCaracteristiques">
        <h3><i class='bx bx-home-alt-2'></i> Caractéristiques du logement</h3>
        <div class="form-grid-3" style="margin-bottom:1.5rem;">
          <div class="form-group">
            <label class="form-label">Chambres *</label>
            <input type="number" name="nbChambres" id="nbChambres"
                   class="form-control" min="0" placeholder="2" required>
          </div>
          <div class="form-group">
            <label class="form-label">Salons *</label>
            <input type="number" name="nbSalons" id="nbSalons"
                   class="form-control" min="0" placeholder="1" required>
          </div>
          <div class="form-group">
            <label class="form-label">Douches *</label>
            <input type="number" name="nbDouches" id="nbDouches"
                   class="form-control" min="0" placeholder="1" required>
          </div>
          <div class="form-group">
            <label class="form-label">Cuisines *</label>
            <input type="number" name="nbCuisines" id="nbCuisines"
                   class="form-control" min="0" placeholder="1" required>
          </div>
          <div class="form-group">
            <label class="form-label" style="color:#D4AF37;">Nb. pièces (auto)</label>
            <input type="number" name="nbPieces" id="nbPieces" class="form-control" min="0" readonly
                   style="background:#F5F5F5; color:#6B6B6B; cursor:not-allowed;">
          </div>
        </div>
        <div class="form-grid-3">
          <div class="form-group">
            <label class="form-label">Électricité *</label>
            <select name="electriciteType" class="form-control" required>
              <option value="">Choisir...</option>
              <option value="personnel">Compteur personnel</option>
              <option value="commun">Compteur commun</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Type de compteur *</label>
            <select name="electriciteCompteur" class="form-control" required>
              <option value="">Choisir...</option>
              <option value="standard">Standard</option>
              <option value="carte">À carte</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label">Eau *</label>
            <select name="eauType" class="form-control" required>
              <option value="">Choisir...</option>
              <option value="personnel">Personnelle</option>
              <option value="commun">Commune</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Message terrain -->
      <div class="form-card" id="cardTerrain" style="display:none;">
        <div style="text-align:center; padding:2rem; color:var(--grey);">
          <i class='bx bx-landscape' style="font-size:3rem; color:var(--gold); display:block; margin-bottom:1rem;"></i>
          <h3 style="color:var(--dark); margin-bottom:0.5rem;">Terrain</h3>
          <p>Les terrains n'ont pas de caractéristiques de logement.<br>Passez directement à l'étape suivante.</p>
        </div>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════
         ÉTAPE 4 : Médias (photos + vidéos)
    ══════════════════════════════════════════════════ -->
    <div class="form-step" data-step="4">
      <div class="form-card">
        <h3><i class='bx bx-images'></i> Photos et vidéos *</h3>
        <p style="font-size:0.85rem; color:var(--grey); margin-bottom:1.25rem;">
          Au moins 1 média requis · Max 10 au total · Max 3 vidéos · Photos : JPG/PNG/WebP · Vidéos : MP4/WebM/MOV (max 50 Mo)
        </p>

        <div class="upload-zone" id="uploadZone" onclick="document.getElementById('mediaInput').click()">
          <input type="file" id="mediaInput" name="medias" multiple
                 accept="image/jpeg,image/png,image/webp,video/mp4,video/webm,video/quicktime"
                 onchange="previewMedias(this)">
          <i class='bx bx-cloud-upload' style="font-size:2.5rem; color:var(--grey); margin-bottom:0.75rem; display:block;"></i>
          <p style="font-weight:600; color:#2C2C2E;">Cliquez pour ajouter des photos ou vidéos</p>
          <p style="font-size:0.82rem; color:var(--grey); margin-top:0.3rem;">Glissez-déposez ou cliquez pour parcourir</p>
        </div>

        <!-- Compteur médias -->
        <div id="mediaCounter" style="display:none; margin-top:0.75rem; font-size:0.85rem; color:var(--grey);">
          <span id="counterPhotos">0 photo(s)</span> · <span id="counterVideos">0 vidéo(s)</span>
        </div>

        <!-- Prévisualisation -->
        <div class="medias-preview" id="mediasPreview"></div>
      </div>
    </div>

    <!-- Navigation wizard -->
    <div class="wizard-nav">
      <a href="/annonces" class="btn btn-outline" id="btnCancel">
        <i class='bx bx-x'></i> Annuler
      </a>
      <div class="wizard-nav-right">
        <button type="button" class="btn btn-outline" id="btnPrev" style="display:none;">
          <i class='bx bx-chevron-left'></i> Précédent
        </button>
        <button type="button" class="btn btn-gold" id="btnNext">
          Suivant <i class='bx bx-chevron-right'></i>
        </button>
        <button type="submit" class="btn btn-gold" id="btnSubmit" style="display:none;">
          <i class='bx bx-check'></i> Publier l'annonce
        </button>
      </div>
    </div>
  </form>
</div>

<script>
// ─── État global du formulaire ────────────────────────────────────
let estVente = false;
let estTerrain = false;

// ─── Toggle transaction ───────────────────────────────────────────
function onTransactionChange(radio) {
  estVente = radio.value === 'vente';
  updateFinancesUI();
}

function onTypeBienChange(select) {
  estTerrain = select.value === 'Terrain';

  // Auto-sélectionner vente si type avec vente par défaut
  const opt = select.options[select.selectedIndex];
  if (opt.dataset.venteDefaut === 'true') {
    document.querySelector('input[name="typeTransaction"][value="vente"]').checked = true;
    estVente = true;
  }

  updateFinancesUI();
  updateCaracteristiquesUI();
}

function updateFinancesUI() {
  const groupDuree = document.getElementById('groupDuree');
  const labelPrix = document.getElementById('labelPrix');
  const inputLoyer = document.getElementById('inputLoyer');
  const inputPrix = document.getElementById('inputPrix');
  const champsLocation = document.querySelectorAll('.form-location-only');

  if (estVente) {
    labelPrix.textContent = 'Prix de vente *';
    inputLoyer.style.display = 'none';
    inputLoyer.removeAttribute('required');
    inputLoyer.value = '';
    inputPrix.style.display = 'block';
    inputPrix.setAttribute('required', 'required');
    groupDuree.style.display = 'none';
    groupDuree.querySelector('select').removeAttribute('required');
    champsLocation.forEach(el => {
      el.style.display = 'none';
      el.querySelector('input').removeAttribute('required');
      el.querySelector('input').value = '0';
    });
  } else {
    labelPrix.textContent = 'Loyer *';
    inputLoyer.style.display = 'block';
    inputLoyer.setAttribute('required', 'required');
    inputPrix.style.display = 'none';
    inputPrix.removeAttribute('required');
    inputPrix.value = '';
    groupDuree.style.display = 'flex';
    groupDuree.querySelector('select').setAttribute('required', 'required');
    champsLocation.forEach(el => {
      el.style.display = 'flex';
      el.querySelector('input').setAttribute('required', 'required');
    });
  }
}

function updateCaracteristiquesUI() {
  const cardCarac = document.getElementById('cardCaracteristiques');
  const cardTerrain = document.getElementById('cardTerrain');

  if (estTerrain) {
    const inputsCarac = cardCarac.querySelectorAll('input, select');
    cardCarac.style.display = 'none';
    cardTerrain.style.display = 'block';
    inputsCarac.forEach(el => el.removeAttribute('required'));
  } else {
    const inputsCarac = cardCarac.querySelectorAll('input, select');
    cardCarac.style.display = 'block';
    cardTerrain.style.display = 'none';
    inputsCarac.forEach(el => {
      if (el.id !== 'nbPieces') el.setAttribute('required', 'required');
    });
  }
}

// ─── Prévisualisation médias ──────────────────────────────────────
let mediaFiles = [];

function previewMedias(input) {
  const newFiles = Array.from(input.files);
  mediaFiles = [...mediaFiles, ...newFiles];
  renderMediasPreview();
}

function renderMediasPreview() {
  const preview = document.getElementById('mediasPreview');
  const counter = document.getElementById('mediaCounter');
  const counterPhotos = document.getElementById('counterPhotos');
  const counterVideos = document.getElementById('counterVideos');

  let nbPhotos = 0, nbVideos = 0;
  preview.innerHTML = '';

  if (mediaFiles.length === 0) {
    counter.style.display = 'none';
    return;
  }

  counter.style.display = 'block';

  mediaFiles.forEach((file, index) => {
    const isVideo = file.type.startsWith('video/');
    if (isVideo) nbVideos++; else nbPhotos++;

    const div = document.createElement('div');
    div.className = 'media-preview-item';
    div.dataset.index = index;

    if (isVideo) {
      const video = document.createElement('video');
      video.src = URL.createObjectURL(file);
      video.muted = true;
      video.style.cssText = 'width:100%; height:100%; object-fit:cover; border-radius:8px;';
      div.appendChild(video);

      const badge = document.createElement('span');
      badge.className = 'media-badge-video';
      badge.innerHTML = "<i class='bx bx-play-circle'></i> Vidéo";
      div.appendChild(badge);
    } else {
      const img = document.createElement('img');
      img.style.cssText = 'width:100%; height:100%; object-fit:cover; border-radius:8px;';
      const reader = new FileReader();
      reader.onload = e => img.src = e.target.result;
      reader.readAsDataURL(file);
      div.appendChild(img);
    }

    // Bouton supprimer
    const btnDel = document.createElement('button');
    btnDel.type = 'button';
    btnDel.className = 'media-preview-delete';
    btnDel.innerHTML = "<i class='bx bx-x'></i>";
    btnDel.onclick = () => {
      mediaFiles.splice(index, 1);
      renderMediasPreview();
      rebuildFileInput();
    };
    div.appendChild(btnDel);
    preview.appendChild(div);
  });

  counterPhotos.textContent = `${nbPhotos} photo${nbPhotos !== 1 ? 's' : ''}`;
  counterVideos.textContent = `${nbVideos} vidéo${nbVideos !== 1 ? 's' : ''}`;

  // Validation visuelle
  const total = nbPhotos + nbVideos;
  counter.style.color = (total > 10 || nbVideos > 3) ? '#dc3545' : 'var(--grey)';
}

function rebuildFileInput() {
  // Reconstruire le FileList depuis mediaFiles via DataTransfer
  const dt = new DataTransfer();
  mediaFiles.forEach(f => dt.items.add(f));
  document.getElementById('mediaInput').files = dt.files;
}

// Drag & drop sur la zone upload
document.addEventListener('DOMContentLoaded', () => {
  const zone = document.getElementById('uploadZone');
  if (!zone) return;

  zone.addEventListener('dragover', e => {
    e.preventDefault();
    zone.classList.add('drag-over');
  });
  zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
  zone.addEventListener('drop', e => {
    e.preventDefault();
    zone.classList.remove('drag-over');
    const files = Array.from(e.dataTransfer.files);
    mediaFiles = [...mediaFiles, ...files];
    renderMediasPreview();
    rebuildFileInput();
  });
});
</script>

<%- include('../partials/footer') %>
