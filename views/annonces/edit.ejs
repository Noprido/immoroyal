<%- include('../partials/header', { title: 'Modifier l\'annonce' }) %>
<%- include('../partials/navbar') %>

<div class="page-form">
  <h1 style="font-size:1.8rem; font-weight:800; margin-bottom:0.5rem;">Modifier <span style="color:#D4AF37;">l'annonce</span></h1>
  <p style="color:#6B6B6B; margin-bottom:2rem;"><%= annonce.titre %></p>

  <% if (error) { %><div class="alert alert-error">⚠️ <%= error %></div><% } %>

  <form action="/annonces/<%= annonce.id %>/edit" method="POST" enctype="multipart/form-data">

    <!-- Infos générales -->
    <div class="form-card">
      <h3>📋 Informations générales</h3>
      <div class="form-grid-2">
        <div class="form-group" style="grid-column:1/-1;">
          <label class="form-label">Titre *</label>
          <input type="text" name="titre" class="form-control" value="<%= annonce.titre %>" required>
        </div>
        <div class="form-group">
          <label class="form-label">Type de bien *</label>
          <select name="typeBien" class="form-control" required>
            <option value="">Choisir...</option>
            <% typesBien.forEach(t => { %>
              <option value="<%= t %>" <%= annonce.typeBien === t ? 'selected' : '' %>><%= t %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Ville / Commune *</label>
          <input type="text" name="ville" class="form-control" data-autocomplete="ville"
                 placeholder="Cotonou, Abomey-Calavi..." autocomplete="off"
                 value="<%= annonce.ville %>" required>
        </div>
        <div class="form-group">
          <label class="form-label">Quartier / Village *</label>
          <input type="text" name="quartier" class="form-control" data-autocomplete="quartier"
                 placeholder="Fidjrossè, Akpakpa..." autocomplete="off"
                 value="<%= annonce.quartier %>" required>
        </div>
        <div class="form-group" style="grid-column:1/-1;">
          <label class="form-label">Description (facultatif)</label>
          <textarea name="description" class="form-control"><%= annonce.description || '' %></textarea>
        </div>
      </div>
    </div>

    <!-- Infos financières -->
    <div class="form-card">
      <h3>💰 Informations financières</h3>
      <div class="form-grid-2">
        <div class="form-group">
          <label class="form-label">Loyer (FCFA) *</label>
          <input type="number" name="loyer" class="form-control" value="<%= annonce.loyer %>" min="0" required>
        </div>
        <div class="form-group">
          <label class="form-label">Mois d'avance *</label>
          <input type="number" name="moisAvance" class="form-control" value="<%= annonce.moisAvance || 0 %>" min="0" required>
        </div>
        <div class="form-group">
          <label class="form-label">Caution eau (FCFA) *</label>
          <input type="number" name="cautionEau" class="form-control" value="<%= annonce.cautionEau || 0 %>" min="0" required>
        </div>
        <div class="form-group">
          <label class="form-label">Caution électricité (FCFA) *</label>
          <input type="number" name="cautionElec" class="form-control" value="<%= annonce.cautionElec || 0 %>" min="0" required>
        </div>
        <div class="form-group">
          <label class="form-label">Commission démarcheur (FCFA) *</label>
          <input type="number" name="commissionDemarcheur" class="form-control" value="<%= annonce.commissionDemarcheur || 0 %>" min="0" required>
        </div>
      </div>
    </div>

    <!-- Caractéristiques -->
    <div class="form-card">
      <h3>🏠 Caractéristiques</h3>
      <div class="form-grid-3" style="margin-bottom:1.5rem;">
        <div class="form-group">
          <label class="form-label">Chambres *</label>
          <input type="number" name="nbChambres" id="nbChambres" class="form-control" value="<%= annonce.nbChambres || 0 %>" min="0" required>
        </div>
        <div class="form-group">
          <label class="form-label">Salons *</label>
          <input type="number" name="nbSalons" id="nbSalons" class="form-control" value="<%= annonce.nbSalons || 0 %>" min="0" required>
        </div>
        <div class="form-group">
          <label class="form-label">Douches *</label>
          <input type="number" name="nbDouches" id="nbDouches" class="form-control" value="<%= annonce.nbDouches || 0 %>" min="0" required>
        </div>
        <div class="form-group">
          <label class="form-label">Cuisines *</label>
          <input type="number" name="nbCuisines" id="nbCuisines" class="form-control" value="<%= annonce.nbCuisines || 0 %>" min="0" required>
        </div>
        <div class="form-group">
          <label class="form-label" style="color:#D4AF37;">Nb. pièces (auto)</label>
          <input type="number" name="nbPieces" id="nbPieces" class="form-control" value="<%= annonce.nbPieces || 0 %>" min="1" readonly
                 style="background:#F5F5F5; color:#6B6B6B; cursor:not-allowed;">
        </div>
      </div>
      <div class="form-grid-3">
        <div class="form-group">
          <label class="form-label">Électricité *</label>
          <select name="electriciteType" class="form-control" required>
            <option value="">Choisir...</option>
            <option value="personnel" <%= annonce.electriciteType === 'personnel' ? 'selected' : '' %>>Compteur personnel</option>
            <option value="commun" <%= annonce.electriciteType === 'commun' ? 'selected' : '' %>>Compteur commun</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Type compteur *</label>
          <select name="electriciteCompteur" class="form-control" required>
            <option value="">Choisir...</option>
            <option value="standard" <%= annonce.electriciteCompteur === 'standard' ? 'selected' : '' %>>Standard</option>
            <option value="carte" <%= annonce.electriciteCompteur === 'carte' ? 'selected' : '' %>>À carte</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Eau *</label>
          <select name="eauType" class="form-control" required>
            <option value="">Choisir...</option>
            <option value="personnel" <%= annonce.eauType === 'personnel' ? 'selected' : '' %>>Personnelle</option>
            <option value="commun" <%= annonce.eauType === 'commun' ? 'selected' : '' %>>Commune</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Photos existantes -->
    <% if (annonce.photos && annonce.photos.length > 0) { %>
      <div class="form-card">
        <h3>📸 Photos actuelles</h3>
        <p style="font-size:0.85rem; color:#6B6B6B; margin-bottom:1rem;">Décochez pour supprimer une photo</p>
        <div class="photos-preview">
          <% annonce.photos.forEach(p => { %>
            <div class="photo-preview-item" style="position:relative;">
              <img src="<%= p %>" alt="">
              <label style="position:absolute; top:6px; right:6px; cursor:pointer; background:rgba(0,0,0,0.6); border-radius:50%; width:28px; height:28px; display:flex; align-items:center; justify-content:center;">
                <input type="checkbox" name="photosExistantes" value="<%= p %>" checked style="display:none;"
                       onchange="this.parentElement.style.background = this.checked ? 'rgba(0,0,0,0.6)' : 'rgba(220,53,69,0.8)'">
                <span style="color:#fff; font-size:0.85rem;">✓</span>
              </label>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <!-- Nouvelles photos -->
    <div class="form-card">
      <h3>➕ Ajouter des photos</h3>
      <div class="upload-zone" onclick="document.getElementById('photoInput').click()">
        <input type="file" id="photoInput" name="photos" multiple accept="image/*" onchange="previewPhotos(this)">
        <div style="font-size:2rem; margin-bottom:0.5rem;">📷</div>
        <p style="font-size:0.9rem; color:#6B6B6B;">Cliquez pour ajouter de nouvelles photos</p>
      </div>
      <div class="photos-preview" id="photosPreview"></div>
    </div>

    <!-- Boutons -->
    <div class="owner-actions" style="justify-content:flex-end;">
      <a href="/annonces/<%= annonce.id %>" class="btn btn-outline">Annuler</a>
      <button type="submit" class="btn btn-gold btn-lg">Enregistrer les modifications</button>
    </div>

  </form>
</div>

<%- include('../partials/footer') %>
