<%- include('../partials/header', { title: 'Modifier l\'annonce' }) %>
<%- include('../partials/navbar') %>

<div class="page-form">
  <h1 style="font-size:1.8rem; font-weight:800; margin-bottom:0.5rem;">Modifier <span style="color:#D4AF37;">l'annonce</span></h1>
  <p style="color:#6B6B6B; margin-bottom:2rem;"><%= annonce.titre %></p>

  <% if (error) { %><div class="alert alert-error"><i class='bx bx-error-circle'></i> <%= error %></div><% } %>

  <%
    const estVente = annonce.typeTransaction === 'vente';
    const estTerrain = annonce.typeBien === 'Terrain';
    const prixActuel = annonce.prix || annonce.loyer || 0;
  %>

  <form action="/annonces/<%= annonce.id %>/edit" method="POST" enctype="multipart/form-data">

    <!-- ── Infos générales ── -->
    <div class="form-card">
      <h3><i class='bx bx-clipboard'></i> Informations générales</h3>
      <div class="form-grid-2">
        <div class="form-group" style="grid-column:1/-1;">
          <label class="form-label">Titre *</label>
          <input type="text" name="titre" class="form-control" value="<%= annonce.titre %>" required>
        </div>

        <!-- Type de transaction -->
        <div class="form-group" style="grid-column:1/-1;">
          <label class="form-label">Type de transaction *</label>
          <div class="transaction-toggle">
            <label class="transaction-option">
              <input type="radio" name="typeTransaction" value="location"
                     <%= !estVente ? 'checked' : '' %> onchange="onTransactionChange(this)">
              <span><i class='bx bx-key'></i> À louer</span>
            </label>
            <label class="transaction-option">
              <input type="radio" name="typeTransaction" value="vente"
                     <%= estVente ? 'checked' : '' %> onchange="onTransactionChange(this)">
              <span><i class='bx bx-transfer'></i> À vendre</span>
            </label>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Type de bien *</label>
          <select name="typeBien" id="typeBien" class="form-control" required onchange="onTypeBienChange(this)">
            <option value="">Choisir...</option>
            <% typesBien.forEach(t => { %>
              <option value="<%= t %>"
                <%= annonce.typeBien === t ? 'selected' : '' %>
                <%= typesVenteDefaut.includes(t) ? 'data-vente-defaut="true"' : '' %>>
                <%= t %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label">Ville / Commune *</label>
          <input type="text" name="ville" class="form-control" data-autocomplete="ville"
                 value="<%= annonce.ville %>" autocomplete="off" required>
        </div>
        <div class="form-group">
          <label class="form-label">Quartier / Village *</label>
          <input type="text" name="quartier" class="form-control" data-autocomplete="quartier"
                 value="<%= annonce.quartier %>" autocomplete="off" required>
        </div>
        <div class="form-group" style="grid-column:1/-1;">
          <label class="form-label">Description (facultatif)</label>
          <textarea name="description" class="form-control"><%= annonce.description || '' %></textarea>
        </div>
      </div>
    </div>

    <!-- ── Finances ── -->
    <div class="form-card">
      <h3><i class='bx bx-wallet'></i> Informations financières</h3>
      <div class="form-grid-2">

        <div class="form-group" id="groupPrix">
          <label class="form-label" id="labelPrix"><%= estVente ? 'Prix de vente' : 'Loyer' %> *</label>
          <div style="position:relative;">
            <input type="number" name="loyer" id="inputLoyer" class="form-control"
                   value="<%= estVente ? '' : prixActuel %>"
                   placeholder="50 000" min="0" <%= !estVente ? 'required' : '' %>
                   style="<%= estVente ? 'display:none;' : '' %>">
            <input type="number" name="prix" id="inputPrix" class="form-control"
                   value="<%= estVente ? prixActuel : '' %>"
                   placeholder="5 000 000" min="0" <%= estVente ? 'required' : '' %>
                   style="<%= !estVente ? 'display:none;' : '' %>">
            <span style="position:absolute; right:0.9rem; top:50%; transform:translateY(-50%);
                         font-size:0.8rem; color:var(--grey); pointer-events:none;">FCFA</span>
          </div>
        </div>

        <div class="form-group" id="groupDuree" style="<%= estVente ? 'display:none;' : '' %>">
          <label class="form-label">Durée *</label>
          <select name="dureeLocation" class="form-control" <%= !estVente ? 'required' : '' %>>
            <% dureesLocation.forEach(d => { %>
              <option value="<%= d.value %>"
                <%= (annonce.dureeLocation || 'mois') === d.value ? 'selected' : '' %>>
                <%= d.label %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="form-group form-location-only" style="<%= estVente ? 'display:none;' : '' %>">
          <label class="form-label">Mois d'avance *</label>
          <input type="number" name="moisAvance" class="form-control"
                 value="<%= annonce.moisAvance || 0 %>" min="0" <%= !estVente ? 'required' : '' %>>
        </div>
        <div class="form-group form-location-only" style="<%= estVente ? 'display:none;' : '' %>">
          <label class="form-label">Caution eau (FCFA) *</label>
          <input type="number" name="cautionEau" class="form-control"
                 value="<%= annonce.cautionEau || 0 %>" min="0" <%= !estVente ? 'required' : '' %>>
        </div>
        <div class="form-group form-location-only" style="<%= estVente ? 'display:none;' : '' %>">
          <label class="form-label">Caution électricité (FCFA) *</label>
          <input type="number" name="cautionElec" class="form-control"
                 value="<%= annonce.cautionElec || 0 %>" min="0" <%= !estVente ? 'required' : '' %>>
        </div>

        <div class="form-group">
          <label class="form-label">Commission démarcheur (FCFA) *</label>
          <input type="number" name="commissionDemarcheur" class="form-control"
                 value="<%= annonce.commissionDemarcheur || 0 %>" min="0" required>
        </div>
      </div>
    </div>

    <!-- ── Caractéristiques ── -->
    <div class="form-card" id="cardCaracteristiques" style="<%= estTerrain ? 'display:none;' : '' %>">
      <h3><i class='bx bx-home-alt-2'></i> Caractéristiques</h3>
      <div class="form-grid-3" style="margin-bottom:1.5rem;">
        <div class="form-group">
          <label class="form-label">Chambres *</label>
          <input type="number" name="nbChambres" id="nbChambres" class="form-control"
                 value="<%= annonce.nbChambres || 0 %>" min="0" <%= !estTerrain ? 'required' : '' %>>
        </div>
        <div class="form-group">
          <label class="form-label">Salons *</label>
          <input type="number" name="nbSalons" id="nbSalons" class="form-control"
                 value="<%= annonce.nbSalons || 0 %>" min="0" <%= !estTerrain ? 'required' : '' %>>
        </div>
        <div class="form-group">
          <label class="form-label">Douches *</label>
          <input type="number" name="nbDouches" id="nbDouches" class="form-control"
                 value="<%= annonce.nbDouches || 0 %>" min="0" <%= !estTerrain ? 'required' : '' %>>
        </div>
        <div class="form-group">
          <label class="form-label">Cuisines *</label>
          <input type="number" name="nbCuisines" id="nbCuisines" class="form-control"
                 value="<%= annonce.nbCuisines || 0 %>" min="0" <%= !estTerrain ? 'required' : '' %>>
        </div>
        <div class="form-group">
          <label class="form-label" style="color:#D4AF37;">Nb. pièces (auto)</label>
          <input type="number" name="nbPieces" id="nbPieces" class="form-control"
                 value="<%= annonce.nbPieces || 0 %>" min="0" readonly
                 style="background:#F5F5F5; color:#6B6B6B; cursor:not-allowed;">
        </div>
      </div>
      <div class="form-grid-3">
        <div class="form-group">
          <label class="form-label">Électricité *</label>
          <select name="electriciteType" class="form-control" <%= !estTerrain ? 'required' : '' %>>
            <option value="">Choisir...</option>
            <option value="personnel" <%= annonce.electriciteType === 'personnel' ? 'selected' : '' %>>Compteur personnel</option>
            <option value="commun" <%= annonce.electriciteType === 'commun' ? 'selected' : '' %>>Compteur commun</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Type compteur *</label>
          <select name="electriciteCompteur" class="form-control" <%= !estTerrain ? 'required' : '' %>>
            <option value="">Choisir...</option>
            <option value="standard" <%= annonce.electriciteCompteur === 'standard' ? 'selected' : '' %>>Standard</option>
            <option value="carte" <%= annonce.electriciteCompteur === 'carte' ? 'selected' : '' %>>À carte</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Eau *</label>
          <select name="eauType" class="form-control" <%= !estTerrain ? 'required' : '' %>>
            <option value="">Choisir...</option>
            <option value="personnel" <%= annonce.eauType === 'personnel' ? 'selected' : '' %>>Personnelle</option>
            <option value="commun" <%= annonce.eauType === 'commun' ? 'selected' : '' %>>Commune</option>
          </select>
        </div>
      </div>
    </div>

    <div class="form-card" id="cardTerrain" style="<%= !estTerrain ? 'display:none;' : '' %>">
      <div style="text-align:center; padding:2rem; color:var(--grey);">
        <i class='bx bx-landscape' style="font-size:3rem; color:var(--gold); display:block; margin-bottom:1rem;"></i>
        <h3 style="color:var(--dark); margin-bottom:0.5rem;">Terrain</h3>
        <p>Les terrains n'ont pas de caractéristiques de logement.</p>
      </div>
    </div>

    <!-- ── Médias existants ── -->
    <% const videosExist = annonce.videos || []; %>
    <% const photosExist = annonce.photos || []; %>

    <% if (videosExist.length > 0) { %>
      <div class="form-card">
        <h3><i class='bx bx-video'></i> Vidéos actuelles</h3>
        <p style="font-size:0.85rem; color:#6B6B6B; margin-bottom:1rem;">Décochez pour supprimer une vidéo</p>
        <div class="medias-preview">
          <% videosExist.forEach((v, i) => { %>
            <div class="media-preview-item" style="position:relative;">
              <video src="<%= v %>" muted style="width:100%; height:100%; object-fit:cover; border-radius:8px;"></video>
              <span class="media-badge-video"><i class='bx bx-play-circle'></i> Vidéo</span>
              <label style="position:absolute; top:5px; right:5px; cursor:pointer; background:rgba(0,0,0,0.6); border-radius:50%; width:28px; height:28px; display:flex; align-items:center; justify-content:center;">
                <input type="checkbox" name="videosExistantes" value="<%= v %>" checked style="display:none;"
                       onchange="this.parentElement.style.background = this.checked ? 'rgba(0,0,0,0.6)' : 'rgba(220,53,69,0.8)'">
                <span style="color:#fff; font-size:0.85rem;">✓</span>
              </label>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <% if (photosExist.length > 0) { %>
      <div class="form-card">
        <h3><i class='bx bx-images'></i> Photos actuelles</h3>
        <p style="font-size:0.85rem; color:#6B6B6B; margin-bottom:1rem;">Décochez pour supprimer une photo</p>
        <div class="medias-preview">
          <% photosExist.forEach(p => { %>
            <div class="media-preview-item" style="position:relative;">
              <img src="<%= p %>" alt="" style="width:100%; height:100%; object-fit:cover; border-radius:8px;">
              <label style="position:absolute; top:5px; right:5px; cursor:pointer; background:rgba(0,0,0,0.6); border-radius:50%; width:28px; height:28px; display:flex; align-items:center; justify-content:center;">
                <input type="checkbox" name="photosExistantes" value="<%= p %>" checked style="display:none;"
                       onchange="this.parentElement.style.background = this.checked ? 'rgba(0,0,0,0.6)' : 'rgba(220,53,69,0.8)'">
                <span style="color:#fff; font-size:0.85rem;">✓</span>
              </label>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <!-- ── Nouveaux médias ── -->
    <div class="form-card">
      <h3><i class='bx bx-cloud-upload'></i> Ajouter des médias</h3>
      <p style="font-size:0.85rem; color:var(--grey); margin-bottom:1.25rem;">
        Total médias (existants + nouveaux) : max 10 · max 3 vidéos · Photos : JPG/PNG/WebP · Vidéos : MP4/WebM/MOV (max 50 Mo)
      </p>
      <div class="upload-zone" id="uploadZone" onclick="document.getElementById('mediaInput').click()">
        <input type="file" id="mediaInput" name="medias" multiple
               accept="image/jpeg,image/png,image/webp,video/mp4,video/webm,video/quicktime"
               onchange="previewMedias(this)">
        <i class='bx bx-cloud-upload' style="font-size:2.5rem; color:var(--grey); margin-bottom:0.75rem; display:block;"></i>
        <p style="font-weight:600; color:#2C2C2E;">Cliquez pour ajouter des photos ou vidéos</p>
      </div>
      <div id="mediaCounter" style="display:none; margin-top:0.75rem; font-size:0.85rem; color:var(--grey);">
        <span id="counterPhotos">0 photo(s)</span> · <span id="counterVideos">0 vidéo(s)</span>
      </div>
      <div class="medias-preview" id="mediasPreview"></div>
    </div>

    <!-- ── Boutons ── -->
    <div class="owner-actions" style="justify-content:flex-end;">
      <a href="/annonces/<%= annonce.id %>" class="btn btn-outline">
        <i class='bx bx-x'></i> Annuler
      </a>
      <button type="submit" class="btn btn-gold btn-lg">
        <i class='bx bx-save'></i> Enregistrer les modifications
      </button>
    </div>
  </form>
</div>

<script>
let estVente = <%= estVente ? 'true' : 'false' %>;
let estTerrain = <%= estTerrain ? 'true' : 'false' %>;

function onTransactionChange(radio) {
  estVente = radio.value === 'vente';
  updateFinancesUI();
}

function onTypeBienChange(select) {
  estTerrain = select.value === 'Terrain';
  const opt = select.options[select.selectedIndex];
  if (opt.dataset.venteDefaut === 'true') {
    document.querySelector('input[name="typeTransaction"][value="vente"]').checked = true;
    estVente = true;
  }
  updateFinancesUI();
  updateCaracteristiquesUI();
}

function updateFinancesUI() {
  const groupDuree = document.getElementById('groupDuree');
  const labelPrix = document.getElementById('labelPrix');
  const inputLoyer = document.getElementById('inputLoyer');
  const inputPrix = document.getElementById('inputPrix');
  const champsLocation = document.querySelectorAll('.form-location-only');

  if (estVente) {
    labelPrix.textContent = 'Prix de vente *';
    inputLoyer.style.display = 'none';
    inputLoyer.removeAttribute('required');
    inputLoyer.value = '';
    inputPrix.style.display = 'block';
    inputPrix.setAttribute('required', 'required');
    groupDuree.style.display = 'none';
    groupDuree.querySelector('select').removeAttribute('required');
    champsLocation.forEach(el => {
      el.style.display = 'none';
      el.querySelector('input').removeAttribute('required');
      el.querySelector('input').value = '0';
    });
  } else {
    labelPrix.textContent = 'Loyer *';
    inputLoyer.style.display = 'block';
    inputLoyer.setAttribute('required', 'required');
    inputPrix.style.display = 'none';
    inputPrix.removeAttribute('required');
    inputPrix.value = '';
    groupDuree.style.display = 'flex';
    groupDuree.querySelector('select').setAttribute('required', 'required');
    champsLocation.forEach(el => {
      el.style.display = 'flex';
      el.querySelector('input').setAttribute('required', 'required');
    });
  }
}

function updateCaracteristiquesUI() {
  const cardCarac = document.getElementById('cardCaracteristiques');
  const cardTerrain = document.getElementById('cardTerrain');
  const inputsCarac = cardCarac.querySelectorAll('input, select');
  if (estTerrain) {
    cardCarac.style.display = 'none';
    cardTerrain.style.display = 'block';
    inputsCarac.forEach(el => el.removeAttribute('required'));
  } else {
    cardCarac.style.display = 'block';
    cardTerrain.style.display = 'none';
    inputsCarac.forEach(el => {
      if (el.id !== 'nbPieces') el.setAttribute('required', 'required');
    });
  }
}

// Preview nouveaux médias
let mediaFiles = [];
function previewMedias(input) {
  mediaFiles = [...mediaFiles, ...Array.from(input.files)];
  renderMediasPreview();
}
function renderMediasPreview() {
  const preview = document.getElementById('mediasPreview');
  const counter = document.getElementById('mediaCounter');
  let nbPhotos = 0, nbVideos = 0;
  preview.innerHTML = '';
  if (mediaFiles.length === 0) { counter.style.display = 'none'; return; }
  counter.style.display = 'block';
  mediaFiles.forEach((file, index) => {
    const isVideo = file.type.startsWith('video/');
    if (isVideo) nbVideos++; else nbPhotos++;
    const div = document.createElement('div');
    div.className = 'media-preview-item';
    if (isVideo) {
      const video = document.createElement('video');
      video.src = URL.createObjectURL(file);
      video.muted = true;
      video.style.cssText = 'width:100%; height:100%; object-fit:cover; border-radius:8px;';
      div.appendChild(video);
      const badge = document.createElement('span');
      badge.className = 'media-badge-video';
      badge.innerHTML = "<i class='bx bx-play-circle'></i> Vidéo";
      div.appendChild(badge);
    } else {
      const img = document.createElement('img');
      img.style.cssText = 'width:100%; height:100%; object-fit:cover; border-radius:8px;';
      const reader = new FileReader();
      reader.onload = e => img.src = e.target.result;
      reader.readAsDataURL(file);
      div.appendChild(img);
    }
    const btnDel = document.createElement('button');
    btnDel.type = 'button';
    btnDel.className = 'media-preview-delete';
    btnDel.innerHTML = "<i class='bx bx-x'></i>";
    btnDel.onclick = () => { mediaFiles.splice(index, 1); renderMediasPreview(); rebuildFileInput(); };
    div.appendChild(btnDel);
    preview.appendChild(div);
  });
  document.getElementById('counterPhotos').textContent = `${nbPhotos} photo${nbPhotos !== 1 ? 's' : ''}`;
  document.getElementById('counterVideos').textContent = `${nbVideos} vidéo${nbVideos !== 1 ? 's' : ''}`;
}
function rebuildFileInput() {
  const dt = new DataTransfer();
  mediaFiles.forEach(f => dt.items.add(f));
  document.getElementById('mediaInput').files = dt.files;
}

// Validation nbPieces (depuis edit form sans wizard)
document.addEventListener('DOMContentLoaded', () => {
  const editForm = document.querySelector('form[action*="/edit"]');
  if (!editForm) return;
  editForm.addEventListener('submit', (e) => {
    if (estTerrain) return;
    const nbPieces = parseInt(document.getElementById('nbPieces')?.value) || 0;
    if (nbPieces < 1) {
      e.preventDefault();
      const el = document.getElementById('nbPieces');
      el.style.borderColor = '#dc3545';
      let msg = document.getElementById('nbPiecesError');
      if (!msg) {
        msg = document.createElement('p');
        msg.id = 'nbPiecesError';
        msg.style.cssText = 'color:#dc3545; font-size:0.82rem; margin-top:0.4rem;';
        el.parentNode.appendChild(msg);
      }
      msg.textContent = 'Au moins une pièce est requise.';
      el.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  });
});
</script>

<%- include('../partials/footer') %>
