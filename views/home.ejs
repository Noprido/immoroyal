<%- include('partials/header', { title: 'Accueil' }) %>
<%- include('partials/navbar') %>

<!-- HERO -->
<section class="hero" style="background-image: url('/images/hero-bg.jpg');">
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <h1>Trouvez votre futur logement <span>au Bénin</span></h1>
    <p>Des centaines d'annonces de location vérifiées, publiées par des particuliers et des démarcheurs locaux.</p>
    <div class="hero-actions">
      <a href="/annonces" class="btn btn-gold btn-lg">Rechercher un bien</a>
      <a href="/annonces/creer" class="btn btn-outline btn-lg">Publier une annonce</a>
    </div>
  </div>
</section>

<!-- SEARCH BAR -->
<div class="container">
  <div class="search-bar">
    <h3>Recherche rapide</h3>
    <form action="/annonces" method="GET" class="search-grid">
      <div class="form-group">
        <label class="form-label">Ville / Commune</label>
        <input type="text" name="ville" class="form-control" data-autocomplete="ville"
               placeholder="Cotonou, Abomey-Calavi..." autocomplete="off">
      </div>
      <div class="form-group">
        <label class="form-label">Quartier / Village</label>
        <input type="text" name="quartier" class="form-control" data-autocomplete="quartier"
               placeholder="Fidjrossè, Akpakpa..." autocomplete="off">
      </div>
      <div class="form-group">
        <label class="form-label">Type de bien</label>
        <select name="typeBien" class="form-control">
          <option value="">Tous</option>
          <% TYPES_BIEN.forEach(t => { %>
            <option value="<%= t %>"><%= t %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Transaction</label>
        <select name="typeTransaction" class="form-control">
          <option value="">Vente & Location</option>
          <option value="location">À louer</option>
          <option value="vente">À vendre</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Prix max (FCFA)</label>
        <input type="number" name="prixMax" class="form-control" placeholder="150 000">
      </div>
      <div class="form-group" style="justify-content:flex-end;">
        <button type="submit" class="btn btn-gold btn-full">Rechercher</button>
      </div>
    </form>
  </div>
</div>

<!-- CHIFFRES CLÉS -->
<section class="section section-grey">
  <div class="container">
    <div class="stats-row">
      <div class="stat-item">
        <div class="stat-number"><%= dernieres.length > 0 ? '500+' : '0' %></div>
        <div class="stat-label">Annonces publiées</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <div class="stat-number">12</div>
        <div class="stat-label">Départements couverts</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <div class="stat-number">77</div>
        <div class="stat-label">Communes disponibles</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <div class="stat-number">100%</div>
        <div class="stat-label">Gratuit</div>
      </div>
    </div>
  </div>
</section>

<!-- TYPES DE BIENS -->
<section class="section">
  <div class="container">
    <h2 class="section-title">Parcourir par <span class="gold">type de bien</span></h2>
    <p class="section-subtitle">Trouvez exactement ce que vous cherchez</p>
    <%
    const icones = {
      'Maison': 'bx-home-alt-2',
      'Appartement vide': 'bx-building',
      'Appartement meublé': 'bx-bed',
      'Boutique': 'bx-store',
      'Magasin': 'bx-store-alt',
      'Bureau': 'bx-briefcase',
      'Terrain': 'bx-landscape',
      'Entrée personnelle': 'bx-door-open'
    };
    %>
    <div class="types-grid">
      <% TYPES_BIEN.forEach(type => { %>
        <a href="/annonces?typeBien=<%= encodeURIComponent(type) %>" class="type-card">
          <i class='bx <%= icones[type] || "bx-home" %> type-icon'></i>
          <div class="type-name"><%= type %></div>
        </a>
      <% }) %>
    </div>
  </div>
</section>

<!-- DERNIÈRES ANNONCES -->
<section class="section section-grey">
  <div class="container">
    <% if (success) { %><div class="alert alert-success"><i class='bx bx-check-circle'></i> <%= success %></div><% } %>
    <% if (error) { %><div class="alert alert-error"><i class='bx bx-error-circle'></i> <%= error %></div><% } %>

    <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:2rem; flex-wrap:wrap; gap:1rem;">
      <div>
        <h2 class="section-title" style="margin-bottom:0.25rem;">Dernières <span class="gold">annonces</span></h2>
        <p class="section-subtitle" style="margin-bottom:0;">Les biens publiés récemment sur la plateforme</p>
      </div>
      <a href="/annonces" class="btn btn-outline">Voir tout</a>
    </div>

    <% if (dernieres.length === 0) { %>
      <div class="empty-state">
        <i class='bx bx-home-alt-2' style="font-size:3rem; color:var(--grey); display:block; margin-bottom:1rem;"></i>
        <h3>Aucune annonce pour l'instant</h3>
        <p>Soyez le premier à publier !</p>
        <a href="/annonces/creer" class="btn btn-gold" style="margin-top:1rem;">Publier une annonce</a>
      </div>
    <% } else { %>
      <div class="annonces-grid">
        <% dernieres.forEach(annonce => { %>
          <%
            const estVente = annonce.typeTransaction === 'vente';
            const prix = getPrixAffiche(annonce);
            const duree = getLabelDuree(annonce);
            const miniature = (annonce.photos && annonce.photos.length > 0) ? annonce.photos[0] : null;
          %>
          <a href="/annonces/<%= annonce.id %>" class="card-annonce <%= annonce.enAvant ? 'en-avant' : '' %>">
            <div class="card-photo">
              <% if (annonce.videos && annonce.videos.length > 0) { %>
                <video class="card-video-thumb" preload="metadata" muted playsinline
                      onloadedmetadata="this.currentTime=0.001">
                  <source src="<%= annonce.videos[0] %>" type="video/mp4">
                  <source src="<%= annonce.videos[0] %>" type="video/webm">
                </video>
                <div class="card-video-play">
                  <div class="card-video-play-circle"><i class='bx bx-play'></i></div>
                </div>
              <% } else if (miniature) { %>
                <img src="<%= miniature %>" alt="<%= annonce.titre %>" loading="lazy">
              <% } else { %>
                <div class="card-photo-placeholder"><i class='bx bx-home-alt-2'></i></div>
              <% } %>
              <span class="badge-type"><%= annonce.typeBien %></span>
              <% if (annonce.enAvant) { %><span class="badge-avant"><i class='bx bx-star'></i> En avant</span><% } %>
              <span class="badge-transaction <%= estVente ? 'badge-transaction-vente' : 'badge-transaction-location' %>">
                <i class='bx <%= estVente ? "bx-transfer" : "bx-key" %>'></i>
                <%= estVente ? 'À vendre' : 'À louer' %>
              </span>
            </div>
            <div class="card-body">
              <div class="card-price">
                <%= prix.toLocaleString('fr-FR') %> FCFA
                <% if (!estVente) { %><span><%= duree %></span><% } %>
              </div>
              <div class="card-title"><%= annonce.titre %></div>
              <div class="card-location">
                <i class='bx bx-map'></i>
                <%= annonce.ville %><% if (annonce.quartier) { %>, <%= annonce.quartier %><% } %>
              </div>
              <div class="card-infos">
                <% if (annonce.nbPieces) { %>
                  <span><i class='bx bx-building-house'></i> <%= annonce.nbPieces %> pièce<%= annonce.nbPieces > 1 ? 's' : '' %></span>
                <% } %>
                <% if (annonce.nbDouches) { %>
                  <span><i class='bx bx-droplet'></i> <%= annonce.nbDouches %> douche<%= annonce.nbDouches > 1 ? 's' : '' %></span>
                <% } %>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
      <div style="text-align:center; margin-top:2.5rem;">
        <a href="/annonces" class="btn btn-outline">Voir toutes les annonces</a>
      </div>
    <% } %>
  </div>
</section>

<!-- COMMENT ÇA MARCHE -->
<section class="section">
  <div class="container">
    <h2 class="section-title" style="text-align:center;">Comment ça <span class="gold">marche ?</span></h2>
    <p class="section-subtitle" style="text-align:center;">Trouver ou publier un logement n'a jamais été aussi simple</p>
    <div class="steps-grid">
      <div class="step-item">
        <div class="step-number">1</div>
        <h4>Recherchez</h4>
        <p>Entrez votre ville, votre quartier et vos critères. Des centaines d'annonces s'offrent à vous en quelques secondes.</p>
      </div>
      <div class="step-arrow">→</div>
      <div class="step-item">
        <div class="step-number">2</div>
        <h4>Contactez</h4>
        <p>Envoyez un message directement au propriétaire ou au démarcheur via notre messagerie intégrée.</p>
      </div>
      <div class="step-arrow">→</div>
      <div class="step-item">
        <div class="step-number">3</div>
        <h4>Emménagez</h4>
        <p>Visitez le bien, signez votre contrat et installez-vous. ImmoRoyal vous a accompagné jusqu'au bout.</p>
      </div>
    </div>
  </div>
</section>

<!-- TÉMOIGNAGES -->
